{
  "name": "mula",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "VITE_BRANCH=\"$(git rev-parse --abbrev-ref HEAD 2>/dev/null)\" vite",
    "dev:sidecar": "bun run src/sidecar/index.ts",
    "dev:all": "bun run dev:sidecar & bun run dev",
    "build": "vite build",
    "build:sidecar": "bun build src/sidecar/index.ts --compile --outfile src-tauri/binaries/mula-sidecar-$(rustc -vV | grep host | cut -d' ' -f2)",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pkill -f 'target/debug/mula' 2>/dev/null; sleep 0.3; bun run build:sidecar && tauri dev",
    "tauri:build": "bun run build:sidecar && tauri build",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run format && bun run lint"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.3",
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@base-ui/react": "^1.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "constrained-editor-plugin": "^1.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "motion": "^12.33.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^3.6.3",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "oxfmt": "^0.23.0",
    "oxlint": "^1.38.0",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.1"
  }
}
